[Unit]
Description=IBKR Bridge API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ibkr
Group=ibkr
WorkingDirectory=/opt/stock-scanner-cloud
EnvironmentFile=/etc/ibkr-bridge.env
ExecStart=/usr/bin/python3 /opt/stock-scanner-cloud/ibkr_bridge/app.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
