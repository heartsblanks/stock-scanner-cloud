IBKR_GATEWAY_HOME=/home/ibkr/Jts
IBKR_GATEWAY_LAUNCHER=/home/ibkr/Jts/ibgateway/ibgateway
IBKR_GATEWAY_USER=ibkr
IBKR_GATEWAY_DISPLAY=:99

# Optional launcher flags for your local install.
# Example:
# IBKR_GATEWAY_ARGS="--mode=paper"
IBKR_GATEWAY_ARGS=

# Bridge/gateway readiness checks
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_GATEWAY_WAIT_TIMEOUT_SECONDS=60

# Bridge readiness probe
IBKR_BRIDGE_READY_BASE_URL=http://127.0.0.1:8090
IBKR_BRIDGE_READY_TIMEOUT_SECONDS=15
IBKR_READINESS_SYMBOL=SPY
